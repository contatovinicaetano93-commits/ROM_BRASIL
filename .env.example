# =============================================================================
# ARQUITETURA VERCEL — DOIS PAINÉIS ISOLADOS (recomendado)
# =============================================================================
# Crie DOIS projetos na Vercel apontando para o MESMO repositório GitHub:
#
#   Projeto A: rom-club-brasil    → ROM CLUB BRASIL
#   Projeto B: rom-club-iguatemi  → ROM CLUB IGUATEMI
#
# Cada projeto tem Environment Variables PRÓPRIAS em Production.
# NUNCA compartilhe DATABASE_URL nem AVEC_API_TOKEN entre os dois.
#
# Domínios sugeridos:
#   brasil.romclub.com.br  → projeto Brasil
#   iguatemi.romclub.com.br → projeto Iguatemi
# =============================================================================

# --- Neon (1 banco POR projeto Vercel) ---
DATABASE_URL=

# --- Painel desta instância (mesmo valor nos dois campos) ---
ROM_PANEL=brasil
NEXT_PUBLIC_ROM_PANEL=brasil
ROM_SEED_PRESET=brasil

# IA — pode ser a mesma chave Anthropic nos dois projetos (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# WhatsApp — 1 instância Evolution POR unidade (número diferente)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
WHATSAPP_WEBHOOK_SECRET=

# Telegram — 1 bot POR unidade (recomendado)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STAFF_CHAT_IDS=

# Avec — TOKEN DIFERENTE por unidade (API da loja Brasil ≠ Iguatemi)
AVEC_API_URL=https://api.avec.beauty
AVEC_API_TOKEN=
AVEC_SYNC_MAX_PAGES=
AVEC_WEBHOOK_SECRET=

# Cron — segredo ÚNICO por projeto Vercel (evita que um cron dispare no outro)
CRON_SECRET=

# Login — senha POR unidade (recomendado)
ROM_ADMIN_USER=admin
ROM_ADMIN_PASSWORD=
ROM_ACCESS_TOKEN=

# Demo Avec sem token (só desenvolvimento)
AVEC_MOCK=

# =============================================================================
# EXEMPLO — Projeto Vercel "rom-club-iguatemi" (Production)
# =============================================================================
# ROM_PANEL=iguatemi
# NEXT_PUBLIC_ROM_PANEL=iguatemi
# ROM_SEED_PRESET=iguatemi
# DATABASE_URL=postgresql://...neon...iguatemi...   ← banco dedicado
# AVEC_API_TOKEN=token_da_loja_iguatemi              ← token Avec Iguatemi
# EVOLUTION_API_INSTANCE=rom-iguatemi
# CRON_SECRET=(openssl rand -hex 32)                 ← diferente do Brasil
# Webhooks apontam para https://iguatemi.romclub.com.br/api/webhooks/...
# =============================================================================
